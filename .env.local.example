# Jarvis Command Center — Supabase connection
# Copy to .env.local (gitignored). Publishable key is safe for the browser; never commit the service_role key.

NEXT_PUBLIC_SUPABASE_URL=https://hxastxplmyowqmaypqip.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_FzCl_YaDijX3exdCxlPiSw_ZI0lF3kC

# Server-only (the Jarvis runner / sync). Get from Supabase dashboard > Settings > API.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional — ElevenLabs natural voice for the Ask panel (server-side only).
# Without it, Ask falls back to the browser's built-in speech synthesis.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB   # default: Adam
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# --- Morning INTEL refresh (scripts/intel.mjs, run by cron) ---
# Gmail read (REQUIRED for inbox intel). Desktop-app OAuth client in Google Cloud,
# then `npm run gmail-auth` mints the refresh token. See HEADLESS-INTEL-SETUP.md.
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
#
# Microsoft 365 read (OPTIONAL — Graph app w/ Mail.Read app-permission, admin consent).
# MS_TENANT_ID=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_USER=collin@leavenwealth.com   # mailbox UPN to read
#
# INTEL_MODEL=claude-sonnet-4-6     # optional override for the summarizer model
# INTEL_WEB=1                       # opt-in: let the intel summarizer use web search/fetch to verify/enrich claims (off by default — costs $ + latency on every cron run)
# INTEL_WEB_MAX=5                   # cost-guard: max web search + fetch uses per run, per tool (default 5). Bounds runaway cost when INTEL_WEB=1.

# Optional: base URL of the Flip Tracker app, enables the flip "Open in Flip Tracker" click-out on /sales/[id]
NEXT_PUBLIC_FLIP_TRACKER_URL=

# --- PGO / Buildium BigQuery (read-only) ---
PGO_BQ_KEY_PATH=/absolute/path/to/pgo-bq-reader.json
PGO_BQ_BILLING_PROJECT=crypto-lodge-499921-h9
PGO_BQ_DATASET=api-data-pull-492404.pgo_shared
